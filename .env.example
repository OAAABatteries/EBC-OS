# ═══════════════════════════════════════════════════════════════
#  EBC-OS · Environment Variables
#  Copy this file to .env and fill in your Supabase credentials.
#  Get these from: https://supabase.com/dashboard → Project → Settings → API
# ═══════════════════════════════════════════════════════════════

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here
# Private key goes in Netlify env vars as VAPID_PRIVATE_KEY (never in client code)
# Also set VAPID_SUBJECT=mailto:admin@ebconstructors.com in Netlify
